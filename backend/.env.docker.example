# Example env for local Docker: copy to `.env.docker` (keep secret; do not commit).
#
#   docker build -t maillardmap-api -f Dockerfile .
#   docker run --rm -p 3001:3000 --env-file .env.docker maillardmap-api
#
# Use host port 3001 if 3000 is busy: -p 3001:3000
# Inside the container PORT should stay 3000 unless you change listen logic.

PORT=3000

# Production / Supabase-style URL with sslmode=require as needed
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

JWT_SECRET=replace-with-at-least-32-random-characters

# Public HTTPS URL of THIS API (Railway/Render URL or localhost for smoke tests)
PUBLIC_API_BASE_URL=http://localhost:3001

RESEND_API_KEY=
RESEND_FROM=onboarding@yourdomain.com
# RESEND_FROM_NAME=MaillardMap

FOURSQUARE_API_KEY=

S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=
# S3_PUBLIC_URL_LEGACY=
