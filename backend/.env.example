# Copy to `.env` and fill in values. See README for quick start.

# --- Core ---
PORT=3000

# Must match your Postgres user, password, and database.
# Repo docker-compose defaults: user maillardmap, password change-me, DB maillardmap
# If you see "password authentication failed" after renaming POSTGRES_*: the data volume
# was likely created with old credentials — run `docker compose down -v` from repo root
# (drops local DB data) then `docker compose up -d` and migrate again.
DATABASE_URL=postgresql://maillardmap:change-me@localhost:5432/maillardmap

# Min 32 characters (required in production).
JWT_SECRET=replace-with-at-least-32-random-characters

# --- Email confirmation (Resend) ---
# Omit RESEND_API_KEY in local dev to skip sending mail (see server logs).
# If RESEND_API_KEY is set, RESEND_FROM is required (verified sender/domain in Resend).
RESEND_API_KEY=
# Verified domain address in Resend (bare email is fine; display name is RESEND_FROM_NAME).
RESEND_FROM=onboarding@yourdomain.com
# Inbox sender name (default MaillardMap if unset)
# RESEND_FROM_NAME=MaillardMap

# Base URL of this API as reachable from the user's email client (no trailing slash).
# Used to build confirmation links: {PUBLIC_API_BASE_URL}/auth/verify-email?token=...
# Falls back to API_PUBLIC_URL, then http://localhost:3000.
PUBLIC_API_BASE_URL=http://localhost:3000
# API_PUBLIC_URL=

# --- Places ---
FOURSQUARE_API_KEY=

# --- Object storage (S3-compatible, e.g. R2 / MinIO) ---
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=
# Optional: rewrite old public URLs to S3_PUBLIC_URL (no trailing slash).
# S3_PUBLIC_URL_LEGACY=
