<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Essential App Metadata -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>com.bigback.app</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>BigBack</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- Core Capabilities Required for BigBack Features -->
    <key>UIRequiresFullScreen</key>
    <true/>

    <!-- Location Usage (For Mapbox) -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>BigBack uses your location to show nearby restaurants and your posts on the map. Location access is only used in background when the app is running to provide seamless navigation between your posts and local restaurants.</string>

    <!-- Photography Features -->
    <key>NSCameraUsageDescription</key>
    <string>BigBack needs access to your camera to take photos for your restaurant posts and memories. This allows you to capture and share your food experiences instantly.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>BigBack needs access to your photo library to allow you to select photos from your existing collection for your restaurant posts and memories. This helps you share your favorite dining moments.</string>

    <!-- Audio Usage (Optional recording features) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>BigBack may need access to your microphone for future recording features to capture audio clips of your restaurant experiences or friend recommendations.</string>

    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
    </array>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- App-Specific Features -->
    <key>UIApplicationWhenInBackgroundKey</key>
    <true/>
    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
        <string>fetch</string>
    </array>
</dict>
</plist>